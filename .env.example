# ──────────────────────────────────────────────────────────────────────────────
# .env — Environment Variables for AI-Driven SQL Agent
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub.
# ──────────────────────────────────────────────────────────────────────────────

# Your Google Gemini API key (get it free at https://aistudio.google.com/api-keys)
GEMINI_API_KEY=your_gemini_api_key_here

# Path to the SQLite database file (auto-created on first file upload)
DB_PATH=database/data.db
